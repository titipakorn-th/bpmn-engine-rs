  "id": "https://example.org/bpmn-engine/project",
  "type": "bpmn:Project",
  "name": "BPMN Engine Rust Implementation",
  "description": "BPMN 2.0 execution engine implemented in Rust, based on bpmn-engine npm package. Supports BPMN 2.0 JSON format as standard I/O, designed as a Rust crate with future GraphQL API and persistence layer integration. Includes comprehensive test suite with 100% coverage target.",
  "version": "0.1.0",
  "goal": "Provide a high-performance, type-safe BPMN 2.0 execution engine for Rust applications, with activity/capability-based design following DoDAF v2 DM2 principles. Maintain 100% test coverage through TDD practices.",
  "status": "completed",
  "createdAt": "2025-01-27T00:00:00+09:00",
  "updatedAt": "2025-11-10T07:03:00+09:00",
  "license": "Apache-2.0",
  "testCoverage": {
    "target": 100,
    "current": 68,
    "unitTests": 64,
    "integrationTests": 4,
    "docTests": 1
  },
  
  "capability": [
    "https://example.org/bpmn-engine/capability/process-execution",
    "https://example.org/bpmn-engine/capability/bpmn-parsing",
    "https://example.org/bpmn-engine/capability/bpmn-xml-parsing",
    "https://example.org/bpmn-engine/capability/format-detection",
    "https://example.org/bpmn-engine/capability/bpmn-serialization",
    "https://example.org/bpmn-engine/capability/activity-management",
    "https://example.org/bpmn-engine/capability/token-flow-control",
    "https://example.org/bpmn-engine/capability/plugin-system",
    "https://example.org/bpmn-engine/capability/listener-hooks",
    "https://example.org/bpmn-engine/capability/persistence-abstraction",
    "https://example.org/bpmn-engine/capability/test-infrastructure"
  ],
  
  "activity": [
    "https://example.org/bpmn-engine/activity/parse-bpmn-json",
    "https://example.org/bpmn-engine/activity/parse-bpmn-xml",
    "https://example.org/bpmn-engine/activity/detect-bpmn-format",
    "https://example.org/bpmn-engine/activity/parse-bpmn-auto",
    "https://example.org/bpmn-engine/activity/serialize-to-json",
    "https://example.org/bpmn-engine/activity/serialize-to-xml",
    "https://example.org/bpmn-engine/activity/execute-process",
    "https://example.org/bpmn-engine/activity/manage-instance",
    "https://example.org/bpmn-engine/activity/execute-task",
    "https://example.org/bpmn-engine/activity/evaluate-gateway",
    "https://example.org/bpmn-engine/activity/handle-event",
    "https://example.org/bpmn-engine/activity/register-plugin",
    "https://example.org/bpmn-engine/activity/register-listener",
    "https://example.org/bpmn-engine/activity/persist-instance",
    "https://example.org/bpmn-engine/activity/run-tests",
    "https://example.org/bpmn-engine/activity/generate-coverage"
  ],
  
  "performer": [
    {
      "@id": "https://example.org/bpmn-engine/performer/engine",
      "@type": "bpmn:Service",
      "name": "BPMN Engine",
      "description": "Main execution engine for BPMN processes"
    },
    {
      "@id": "https://example.org/bpmn-engine/performer/parser",
      "@type": "bpmn:Service",
      "name": "BPMN Parser",
      "description": "Parser for BPMN 2.0 JSON format"
    },
    {
      "@id": "https://example.org/bpmn-engine/performer/activity-executor",
      "@type": "bpmn:Service",
      "name": "Activity Executor",
      "description": "Executor for BPMN activities (tasks, gateways, events)"
    },
    {
      "@id": "https://example.org/bpmn-engine/performer/repository",
      "@type": "bpmn:System",
      "name": "Repository",
      "description": "Persistence layer for process instances"
    },
    {
      "@id": "https://example.org/bpmn-engine/performer/test-framework",
      "@type": "bpmn:System",
      "name": "Test Framework",
      "description": "Test infrastructure for unit tests, integration tests, and coverage measurement"
    }
  ]
