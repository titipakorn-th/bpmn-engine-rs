{
  "@context": {
    "@version": 1.1,
    "id": "@id",
    "type": "@type",
    "dct": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "bpmn": "https://example.org/bpmn-engine#",
    "prov": "http://www.w3.org/ns/prov#",
    
    "name": "dct:title",
    "description": "dct:description",
    "capability": {"@id": "bpmn:requiresCapability", "@type": "@id", "@container": "@set"},
    "input": {"@id": "bpmn:hasInput", "@type": "@id", "@container": "@set"},
    "output": {"@id": "bpmn:hasOutput", "@type": "@id", "@container": "@set"},
    "performer": {"@id": "prov:wasPerformedBy", "@type": "@id"}
  },
  
  "@graph": [
    {
      "id": "https://example.org/bpmn-engine/activity/parse-bpmn-json",
      "type": "bpmn:Activity",
      "name": "Parse BPMN JSON",
      "description": "Parse BPMN 2.0 JSON format definition into internal process model representation.",
      "capability": ["https://example.org/bpmn-engine/capability/bpmn-parsing"],
      "input": [
        {"@id": "bpmn:Input", "name": "bpmn_json", "type": "xsd:string"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "process_model", "type": "bpmn:ProcessModel"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/parser"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/parse-bpmn-xml",
      "type": "bpmn:Activity",
      "name": "Parse BPMN XML",
      "description": "Parse BPMN 2.0 XML format definition into internal process model representation.",
      "capability": ["https://example.org/bpmn-engine/capability/bpmn-xml-parsing"],
      "input": [
        {"@id": "bpmn:Input", "name": "bpmn_xml", "type": "xsd:string"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "process_model", "type": "bpmn:ProcessModel"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/parser"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/detect-bpmn-format",
      "type": "bpmn:Activity",
      "name": "Detect BPMN Format",
      "description": "Detect the format (JSON/XML) of input BPMN data with confidence score.",
      "capability": ["https://example.org/bpmn-engine/capability/format-detection"],
      "input": [
        {"@id": "bpmn:Input", "name": "input_data", "type": "xsd:string"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "format", "type": "xsd:string"},
        {"@id": "bpmn:Output", "name": "confidence", "type": "xsd:double"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/parser"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/parse-bpmn-auto",
      "type": "bpmn:Activity",
      "name": "Parse BPMN Auto",
      "description": "Automatically detect format and parse BPMN definition (supports both JSON and XML).",
      "capability": [
        "https://example.org/bpmn-engine/capability/format-detection",
        "https://example.org/bpmn-engine/capability/bpmn-parsing",
        "https://example.org/bpmn-engine/capability/bpmn-xml-parsing"
      ],
      "input": [
        {"@id": "bpmn:Input", "name": "input_data", "type": "xsd:string"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "process_model", "type": "bpmn:ProcessModel"},
        {"@id": "bpmn:Output", "name": "detected_format", "type": "xsd:string"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/parser"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/serialize-to-json",
      "type": "bpmn:Activity",
      "name": "Serialize to JSON",
      "description": "Serialize ProcessDefinition to BPMN 2.0 JSON format.",
      "capability": ["https://example.org/bpmn-engine/capability/bpmn-serialization"],
      "input": [
        {"@id": "bpmn:Input", "name": "process_model", "type": "bpmn:ProcessModel"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "bpmn_json", "type": "xsd:string"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/parser"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/serialize-to-xml",
      "type": "bpmn:Activity",
      "name": "Serialize to XML",
      "description": "Serialize ProcessDefinition to BPMN 2.0 XML format.",
      "capability": ["https://example.org/bpmn-engine/capability/bpmn-serialization"],
      "input": [
        {"@id": "bpmn:Input", "name": "process_model", "type": "bpmn:ProcessModel"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "bpmn_xml", "type": "xsd:string"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/parser"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/execute-process",
      "type": "bpmn:Activity",
      "name": "Execute Process",
      "description": "Execute a BPMN process instance, managing execution flow through activities and sequence flows.",
      "capability": [
        "https://example.org/bpmn-engine/capability/process-execution",
        "https://example.org/bpmn-engine/capability/token-flow-control"
      ],
      "input": [
        {"@id": "bpmn:Input", "name": "process_definition", "type": "bpmn:ProcessDefinition"},
        {"@id": "bpmn:Input", "name": "initial_variables", "type": "bpmn:Variables"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "process_instance", "type": "bpmn:ProcessInstance"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/engine"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/manage-instance",
      "type": "bpmn:Activity",
      "name": "Manage Process Instance",
      "description": "Manage process instance state, execution context, and token flow through the process.",
      "capability": [
        "https://example.org/bpmn-engine/capability/process-execution",
        "https://example.org/bpmn-engine/capability/token-flow-control"
      ],
      "input": [
        {"@id": "bpmn:Input", "name": "instance_id", "type": "xsd:string"},
        {"@id": "bpmn:Input", "name": "action", "type": "bpmn:InstanceAction"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "instance_state", "type": "bpmn:InstanceState"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/engine"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/execute-task",
      "type": "bpmn:Activity",
      "name": "Execute Task",
      "description": "Execute a BPMN task (ServiceTask, UserTask, ScriptTask, etc.) with its associated behavior.",
      "capability": ["https://example.org/bpmn-engine/capability/activity-management"],
      "input": [
        {"@id": "bpmn:Input", "name": "task_definition", "type": "bpmn:TaskDefinition"},
        {"@id": "bpmn:Input", "name": "execution_context", "type": "bpmn:ExecutionContext"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "task_result", "type": "bpmn:TaskResult"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/activity-executor"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/evaluate-gateway",
      "type": "bpmn:Activity",
      "name": "Evaluate Gateway",
      "description": "Evaluate gateway conditions and determine outgoing sequence flows (ExclusiveGateway, ParallelGateway, InclusiveGateway, etc.).",
      "capability": ["https://example.org/bpmn-engine/capability/activity-management"],
      "input": [
        {"@id": "bpmn:Input", "name": "gateway_definition", "type": "bpmn:GatewayDefinition"},
        {"@id": "bpmn:Input", "name": "execution_context", "type": "bpmn:ExecutionContext"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "selected_flows", "type": "bpmn:SequenceFlowList"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/activity-executor"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/handle-event",
      "type": "bpmn:Activity",
      "name": "Handle Event",
      "description": "Handle BPMN events (StartEvent, EndEvent, IntermediateCatchEvent, IntermediateThrowEvent, etc.).",
      "capability": ["https://example.org/bpmn-engine/capability/activity-management"],
      "input": [
        {"@id": "bpmn:Input", "name": "event_definition", "type": "bpmn:EventDefinition"},
        {"@id": "bpmn:Input", "name": "execution_context", "type": "bpmn:ExecutionContext"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "event_result", "type": "bpmn:EventResult"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/activity-executor"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/register-plugin",
      "type": "bpmn:Activity",
      "name": "Register Plugin",
      "description": "Register a plugin to extend engine functionality with custom activity factories and behaviors.",
      "capability": ["https://example.org/bpmn-engine/capability/plugin-system"],
      "input": [
        {"@id": "bpmn:Input", "name": "plugin", "type": "bpmn:Plugin"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "registration_result", "type": "bpmn:RegistrationResult"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/engine"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/register-listener",
      "type": "bpmn:Activity",
      "name": "Register Listener",
      "description": "Register a process execution listener to receive events during process execution.",
      "capability": ["https://example.org/bpmn-engine/capability/listener-hooks"],
      "input": [
        {"@id": "bpmn:Input", "name": "listener", "type": "bpmn:ProcessListener"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "registration_result", "type": "bpmn:RegistrationResult"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/engine"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/persist-instance",
      "type": "bpmn:Activity",
      "name": "Persist Instance",
      "description": "Persist a process instance to the repository (currently in-memory, designed for future database integration).",
      "capability": ["https://example.org/bpmn-engine/capability/persistence-abstraction"],
      "input": [
        {"@id": "bpmn:Input", "name": "instance", "type": "bpmn:ProcessInstance"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "persistence_result", "type": "bpmn:PersistenceResult"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/repository"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/run-tests",
      "type": "bpmn:Activity",
      "name": "Run Tests",
      "description": "Execute test suites including unit tests (64 tests), integration tests (4 tests), and doc tests (1 test).",
      "capability": ["https://example.org/bpmn-engine/capability/test-infrastructure"],
      "input": [
        {"@id": "bpmn:Input", "name": "test_suite", "type": "xsd:string"},
        {"@id": "bpmn:Input", "name": "test_filter", "type": "xsd:string"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "test_results", "type": "bpmn:TestResults"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/test-framework"
    },
    {
      "id": "https://example.org/bpmn-engine/activity/generate-coverage",
      "type": "bpmn:Activity",
      "name": "Generate Coverage",
      "description": "Generate code coverage report using cargo-llvm-cov, targeting 100% coverage.",
      "capability": ["https://example.org/bpmn-engine/capability/test-infrastructure"],
      "input": [
        {"@id": "bpmn:Input", "name": "output_format", "type": "xsd:string"},
        {"@id": "bpmn:Input", "name": "output_path", "type": "xsd:string"}
      ],
      "output": [
        {"@id": "bpmn:Output", "name": "coverage_report", "type": "bpmn:CoverageReport"}
      ],
      "performer": "https://example.org/bpmn-engine/performer/test-framework"
    }
  ]
}

